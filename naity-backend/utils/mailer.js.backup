const nodemailer = require("nodemailer");
require("dotenv").config();

// إعداد المُرسِل
const transporter = nodemailer.createTransport({
  host: process.env.MAIL_HOST,
  port: parseInt(process.env.MAIL_PORT) || 465,
  secure: true,
  auth: {
    user: process.env.MAIL_USER,
    pass: process.env.MAIL_PASS,
  },
});

// ✅ إرسال تأكيد الحجز للعميل
const sendBookingConfirmation = async (booking, language = 'ar') => {
  const {
    guest_first_name,
    guest_last_name,
    guest_email,
    hotel_name,
    hotel_name_ar,
    city,
    check_in,
    check_out,
    total_price,
    deposit_amount,
    remaining_amount,
    guests_count,
    room_type,
    room_type_ar,
    id,
    transaction_hash,
    hotel_phone,
    hotel_address,
    check_in_time,
    check_out_time,
  } = booking;

  const isArabic = language === 'ar';
  const displayHotelName = isArabic ? (hotel_name_ar || hotel_name) : hotel_name;
  const displayRoomType = isArabic ? (room_type_ar || room_type) : room_type;
  const bookingRef = `NAITY-${new Date().getFullYear()}-${String(id).padStart(6, '0')}`;
  const remainingAmt = remaining_amount || (total_price - deposit_amount);

  const mailOptions = {
    from: process.env.MAIL_FROM,
    to: guest_email,
    subject: isArabic
      ? `تم تأكيد الحجز – إقامتك في ${displayHotelName} 🎉`
      : `Booking Confirmed – Your Stay with ${displayHotelName} 🎉`,
    html: `
      <div dir="rtl" style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px; border: 1px solid #e2e8f0; border-radius: 12px;">
        <div style="text-align: center; margin-bottom: 24px;">
          <h1 style="color: #1a56db; font-size: 28px; margin: 0;">🏨 Naity</h1>
          <p style="color: #64748b; margin-top: 4px;">منصة حجز الفنادق</p>
        </div>

        <div style="background: #f0f9ff; border-radius: 8px; padding: 20px; margin-bottom: 20px;">
          <h2 style="color: #0369a1; margin: 0 0 8px;">تم تأكيد حجزك بنجاح! 🎉</h2>
          <p style="color: #475569; margin: 0;">عزيزنا ${guest_first_name} ${guest_last_name}، شكراً لاختيارك Naity</p>
        </div>

        <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
          <tr style="background: #f8fafc;">
            <td style="padding: 12px; border: 1px solid #e2e8f0; font-weight: bold; color: #374151;">الفندق</td>
            <td style="padding: 12px; border: 1px solid #e2e8f0; color: #1f2937;">${hotel_name}</td>
          </tr>
          <tr>
            <td style="padding: 12px; border: 1px solid #e2e8f0; font-weight: bold; color: #374151;">تاريخ الوصول</td>
            <td style="padding: 12px; border: 1px solid #e2e8f0; color: #1f2937;">${check_in}</td>
          </tr>
          <tr style="background: #f8fafc;">
            <td style="padding: 12px; border: 1px solid #e2e8f0; font-weight: bold; color: #374151;">تاريخ المغادرة</td>
            <td style="padding: 12px; border: 1px solid #e2e8f0; color: #1f2937;">${check_out}</td>
          </tr>
          <tr>
            <td style="padding: 12px; border: 1px solid #e2e8f0; font-weight: bold; color: #374151;">المجموع الكلي</td>
            <td style="padding: 12px; border: 1px solid #e2e8f0; color: #1f2937; font-weight: bold;">${total_price} $</td>
          </tr>
          <tr style="background: #fef9c3;">
            <td style="padding: 12px; border: 1px solid #e2e8f0; font-weight: bold; color: #374151;">العربون المدفوع</td>
            <td style="padding: 12px; border: 1px solid #e2e8f0; color: #b45309; font-weight: bold;">${deposit_amount} $</td>
          </tr>
          <tr>
            <td style="padding: 12px; border: 1px solid #e2e8f0; font-weight: bold; color: #374151;">رقم الحجز</td>
            <td style="padding: 12px; border: 1px solid #e2e8f0; color: #6366f1; font-family: monospace;">${id}</td>
          </tr>
        </table>

        ${transaction_hash ? `
        <div style="background: #f0fdf4; border-radius: 8px; padding: 16px; margin-bottom: 20px;">
          <p style="margin: 0; color: #166534; font-size: 14px;">
            🔐 <strong>رمز التحقق:</strong> <code style="font-family: monospace; background: #dcfce7; padding: 2px 6px; border-radius: 4px;">${transaction_hash}</code>
          </p>
        </div>
        ` : ""}

        <div style="text-align: center; color: #64748b; font-size: 13px; margin-top: 24px; padding-top: 16px; border-top: 1px solid #e2e8f0;">
          <p>هذا البريد تم إرساله تلقائياً من منصة Naity</p>
          <p>للاستفسار: <a href="mailto:info@naitagfz.com" style="color: #1a56db;">info@naitagfz.com</a></p>
        </div>
      </div>
    `,
  };

  try {
    await transporter.sendMail(mailOptions);
    console.log(`📧 Email sent to ${guest_email}`);
    return true;
  } catch (err) {
    console.error("❌ Failed to send email:", err.message);
    return false;
  }
};

// ✅ إرسال إشعار للفندق عند وجود حجز جديد
const sendHotelNotification = async (booking, hotelEmail) => {
  if (!hotelEmail) return false;

  const mailOptions = {
    from: process.env.MAIL_FROM,
    to: hotelEmail,
    subject: `🔔 حجز جديد - ${booking.guest_first_name} ${booking.guest_last_name}`,
    html: `
      <div dir="rtl" style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
        <h2 style="color: #1a56db;">🏨 حجز جديد على منصة Naity</h2>
        <table style="width: 100%; border-collapse: collapse;">
          <tr><td style="padding: 8px; border: 1px solid #e2e8f0; font-weight: bold;">العميل</td>
              <td style="padding: 8px; border: 1px solid #e2e8f0;">${booking.guest_first_name} ${booking.guest_last_name}</td></tr>
          <tr><td style="padding: 8px; border: 1px solid #e2e8f0; font-weight: bold;">الهاتف</td>
              <td style="padding: 8px; border: 1px solid #e2e8f0;">${booking.phone_country_code || ""}${booking.guest_phone || "غير محدد"}</td></tr>
          <tr><td style="padding: 8px; border: 1px solid #e2e8f0; font-weight: bold;">البريد</td>
              <td style="padding: 8px; border: 1px solid #e2e8f0;">${booking.guest_email}</td></tr>
          <tr><td style="padding: 8px; border: 1px solid #e2e8f0; font-weight: bold;">الوصول</td>
              <td style="padding: 8px; border: 1px solid #e2e8f0;">${booking.check_in}</td></tr>
          <tr><td style="padding: 8px; border: 1px solid #e2e8f0; font-weight: bold;">المغادرة</td>
              <td style="padding: 8px; border: 1px solid #e2e8f0;">${booking.check_out}</td></tr>
          <tr><td style="padding: 8px; border: 1px solid #e2e8f0; font-weight: bold;">عدد الضيوف</td>
              <td style="padding: 8px; border: 1px solid #e2e8f0;">${booking.guests_count}</td></tr>
          <tr><td style="padding: 8px; border: 1px solid #e2e8f0; font-weight: bold;">المجموع</td>
              <td style="padding: 8px; border: 1px solid #e2e8f0; color: #16a34a; font-weight: bold;">${booking.total_price} $</td></tr>
          ${booking.special_requests ? `<tr><td style="padding: 8px; border: 1px solid #e2e8f0; font-weight: bold;">طلبات خاصة</td>
              <td style="padding: 8px; border: 1px solid #e2e8f0;">${booking.special_requests}</td></tr>` : ""}
        </table>
        <p style="color: #64748b; margin-top: 16px; font-size: 13px;">رقم الحجز: ${booking.id}</p>
      </div>
    `,
  };

  try {
    await transporter.sendMail(mailOptions);
    return true;
  } catch (err) {
    console.error("❌ Failed to send hotel notification:", err.message);
    return false;
  }
};

// ✅ إرسال رسالة من نموذج التواصل إلى support@naity.net
const sendContactFormEmail = async (contactData) => {
  const { full_name, email, phone, country, subject, message } = contactData;

  const subjectLabels = {
    booking_issue: "مشكلة في حجز / Booking Issue",
    hotel_inquiry: "استفسار عن فندق / Hotel Inquiry",
    payment: "استفسار عن الدفع / Payment Question",
    cancellation: "طلب إلغاء / Cancellation Request",
    partnership: "شراكة / Partnership",
    complaint: "شكوى / Complaint",
    suggestion: "اقتراح / Suggestion",
    other: "أخرى / Other",
  };

  const mailOptions = {
    from: process.env.MAIL_FROM,
    to: "support@naity.net",
    replyTo: email,
    subject: `📧 رسالة جديدة من ${full_name} - ${subjectLabels[subject] || subject}`,
    html: `
      <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px; border: 1px solid #e2e8f0; border-radius: 12px;">
        <div style="text-align: center; margin-bottom: 24px;">
          <h1 style="color: #1a56db; font-size: 28px; margin: 0;">🏨 Naity</h1>
          <p style="color: #64748b; margin-top: 4px;">رسالة جديدة من نموذج التواصل</p>
        </div>

        <div style="background: #f0f9ff; border-radius: 8px; padding: 20px; margin-bottom: 20px;">
          <h2 style="color: #0369a1; margin: 0 0 8px;">رسالة جديدة من العميل</h2>
          <p style="color: #475569; margin: 0;">تم استلام رسالة جديدة عبر نموذج التواصل</p>
        </div>

        <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
          <tr style="background: #f8fafc;">
            <td style="padding: 12px; border: 1px solid #e2e8f0; font-weight: bold; color: #374151; width: 150px;">الاسم الكامل</td>
            <td style="padding: 12px; border: 1px solid #e2e8f0; color: #1f2937;">${full_name}</td>
          </tr>
          <tr>
            <td style="padding: 12px; border: 1px solid #e2e8f0; font-weight: bold; color: #374151;">البريد الإلكتروني</td>
            <td style="padding: 12px; border: 1px solid #e2e8f0; color: #1f2937;">
              <a href="mailto:${email}" style="color: #1a56db; text-decoration: none;">${email}</a>
            </td>
          </tr>
          <tr style="background: #f8fafc;">
            <td style="padding: 12px; border: 1px solid #e2e8f0; font-weight: bold; color: #374151;">رقم الهاتف</td>
            <td style="padding: 12px; border: 1px solid #e2e8f0; color: #1f2937;">${phone || "غير محدد"}</td>
          </tr>
          <tr>
            <td style="padding: 12px; border: 1px solid #e2e8f0; font-weight: bold; color: #374151;">الدولة</td>
            <td style="padding: 12px; border: 1px solid #e2e8f0; color: #1f2937;">${country || "غير محدد"}</td>
          </tr>
          <tr style="background: #f8fafc;">
            <td style="padding: 12px; border: 1px solid #e2e8f0; font-weight: bold; color: #374151;">الموضوع</td>
            <td style="padding: 12px; border: 1px solid #e2e8f0; color: #1f2937;">${subjectLabels[subject] || subject}</td>
          </tr>
        </table>

        <div style="background: #fef9c3; border-radius: 8px; padding: 16px; margin-bottom: 20px;">
          <h3 style="color: #854d0e; margin: 0 0 12px; font-size: 16px;">📝 الرسالة:</h3>
          <p style="color: #713f12; margin: 0; white-space: pre-wrap; line-height: 1.6;">${message}</p>
        </div>

        <div style="background: #f0fdf4; border-radius: 8px; padding: 16px; margin-bottom: 20px;">
          <p style="margin: 0; color: #166534; font-size: 14px;">
            💡 <strong>للرد على العميل:</strong> يمكنك الرد مباشرة على هذا البريد أو إرسال رسالة إلى 
            <a href="mailto:${email}" style="color: #166534; font-weight: bold;">${email}</a>
          </p>
        </div>

        <div style="text-align: center; color: #64748b; font-size: 13px; margin-top: 24px; padding-top: 16px; border-top: 1px solid #e2e8f0;">
          <p>هذا البريد تم إرساله تلقائياً من نموذج التواصل على موقع Naity</p>
          <p style="margin-top: 8px;">
            <strong>تاريخ الإرسال:</strong> ${new Date().toLocaleString('ar-SY', { timeZone: 'Asia/Damascus' })}
          </p>
        </div>
      </div>
    `,
  };

  try {
    await transporter.sendMail(mailOptions);
    console.log(`📧 Contact form email sent to support@naity.net from ${email}`);
    return true;
  } catch (err) {
    console.error("❌ Failed to send contact form email:", err.message);
    return false;
  }
};

// ✅ إرسال رد على رسالة تواصل من الإدارة
const sendReplyToContact = async (replyData) => {
  const { recipient_email, recipient_name, original_message, reply_message, admin_name } = replyData;

  const mailOptions = {
    from: process.env.MAIL_FROM,
    to: recipient_email,
    subject: `رد من فريق Naity - Reply from Naity Team`,
    html: `
      <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px; border: 1px solid #e2e8f0; border-radius: 12px;">
        <div style="text-align: center; margin-bottom: 24px;">
          <h1 style="color: #1a56db; font-size: 28px; margin: 0;">🏨 Naity</h1>
          <p style="color: #64748b; margin-top: 4px;">Hotel Booking Platform</p>
        </div>

        <div style="background: #f0f9ff; border-radius: 8px; padding: 20px; margin-bottom: 20px;">
          <h2 style="color: #0369a1; margin: 0 0 8px;">مرحباً ${recipient_name} 👋</h2>
          <h2 style="color: #0369a1; margin: 0 0 8px;">Hello ${recipient_name} 👋</h2>
          <p style="color: #475569; margin: 0;">شكراً لتواصلك معنا. إليك رد فريق Naity على رسالتك</p>
          <p style="color: #475569; margin: 0;">Thank you for contacting us. Here's our response to your message</p>
        </div>

        <div style="background: #fef9c3; border-radius: 8px; padding: 16px; margin-bottom: 20px;">
          <h3 style="color: #854d0e; margin: 0 0 12px; font-size: 16px;">💬 رد فريق Naity / Naity Team Reply:</h3>
          <p style="color: #713f12; margin: 0; white-space: pre-wrap; line-height: 1.6; font-size: 15px;">${reply_message}</p>
          ${admin_name ? `<p style="color: #92400e; margin-top: 12px; font-size: 13px; font-style: italic;">— ${admin_name}</p>` : ''}
        </div>

        ${original_message ? `
        <div style="background: #f8fafc; border-left: 4px solid #cbd5e1; padding: 16px; margin-bottom: 20px;">
          <h4 style="color: #64748b; margin: 0 0 8px; font-size: 13px;">رسالتك الأصلية / Your Original Message:</h4>
          <p style="color: #475569; margin: 0; white-space: pre-wrap; line-height: 1.5; font-size: 13px;">${original_message}</p>
        </div>
        ` : ''}

        <div style="background: #f0fdf4; border-radius: 8px; padding: 16px; margin-bottom: 20px;">
          <p style="margin: 0; color: #166534; font-size: 14px;">
            💡 <strong>هل لديك المزيد من الأسئلة؟ / More questions?</strong><br/>
            يمكنك الرد مباشرة على هذا البريد أو زيارة موقعنا<br/>
            You can reply directly to this email or visit our website
          </p>
        </div>

        <div style="text-align: center; margin-top: 24px;">
          <a href="https://naity.net" style="display: inline-block; background: #1a56db; color: white; padding: 12px 24px; border-radius: 8px; text-decoration: none; font-weight: bold;">
            زيارة الموقع / Visit Website
          </a>
        </div>

        <div style="text-align: center; color: #64748b; font-size: 13px; margin-top: 24px; padding-top: 16px; border-top: 1px solid #e2e8f0;">
          <p>Naity - Hotel Booking Platform</p>
          <p>📧 support@naity.net | 🌐 naity.net</p>
          <p style="margin-top: 8px;">
            <strong>تاريخ الرد / Reply Date:</strong> ${new Date().toLocaleString('ar-SY', { timeZone: 'Asia/Damascus' })}
          </p>
        </div>
      </div>
    `,
  };

  try {
    await transporter.sendMail(mailOptions);
    console.log(`📧 Reply email sent to ${recipient_email}`);
    return true;
  } catch (err) {
    console.error("❌ Failed to send reply email:", err.message);
    return false;
  }
};

// ✅ إرسال رسالة ترحيب للفنادق عند التسجيل
const sendHotelWelcome = async (hotelData, language = 'ar') => {
  const { hotel_name, hotel_name_ar, contact_email, city, stars, created_at, property_type } = hotelData;

  const isArabic = language === 'ar';
  const isApartment = property_type === 'apartment';
  const displayName = isArabic ? (hotel_name_ar || hotel_name) : hotel_name;

  // Dynamic text based on property type
  const propertyLabel = {
    ar: isApartment ? 'شقتك' : 'فندقك',
    en: isApartment ? 'Your Apartment' : 'Your Hotel'
  };

  const propertyIcon = isApartment ? '🏠' : '🏨';
  
  const propertyNameLabel = {
    ar: isApartment ? 'اسم الشقة' : 'اسم الفندق',
    en: isApartment ? 'Apartment Name' : 'Hotel Name'
  };

  const featuresList = {
    ar: isApartment ? [
      '<li><strong>إدارة الحجوزات</strong> من خلال لوحة التحكم الخاصة بكم</li>',
      '<li><strong>تحديث التوافر</strong> بشكل فوري</li>',
      '<li><strong>تحديد الأسعار الخاصة بكم</strong> بدون أي عمولات مخفية</li>',
      '<li><strong>إضافة الصور والوصف</strong> لعرض شقتكم بشكل أفضل</li>'
    ] : [
      '<li><strong>إدارة الحجوزات</strong> من خلال لوحة التحكم الخاصة بكم</li>',
      '<li><strong>تحديث توفر الغرف</strong> بشكل فوري</li>',
      '<li><strong>تحديد الأسعار الخاصة بكم</strong> بدون أي عمولات مخفية</li>',
      '<li><strong>إضافة الصور والوصف</strong> لعرض فندقكم بشكل أفضل</li>'
    ],
    en: isApartment ? [
      '<li><strong>Manage bookings</strong> through your dashboard</li>',
      '<li><strong>Update availability</strong> in real-time</li>',
      '<li><strong>Set your own prices</strong> - no hidden commissions</li>',
      '<li><strong>Add photos and descriptions</strong> to showcase your apartment</li>'
    ] : [
      '<li><strong>Manage bookings</strong> through your dashboard</li>',
      '<li><strong>Update room availability</strong> in real-time</li>',
      '<li><strong>Set your own prices</strong> - no hidden commissions</li>',
      '<li><strong>Add photos and descriptions</strong> to showcase your hotel</li>'
    ]
  };

  const mailOptions = {
    from: process.env.MAIL_FROM,
    to: contact_email,
    subject: isArabic 
      ? `مرحباً بك في Naity – ${propertyLabel.ar} أصبح${isApartment ? 'ت' : ''} متاح${isApartment ? 'ة' : 'اً'} الآن! ${propertyIcon}`
      : `Welcome to Naity - ${propertyLabel.en} is Now Live! ${propertyIcon}`,
    html: isArabic ? `
      <div dir="rtl" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; max-width: 650px; margin: 0 auto; padding: 0; background: #ffffff;">
        <!-- Header with gradient -->
        <div style="background: linear-gradient(135deg, #1a56db 0%, #0369a1 100%); padding: 40px 30px; text-align: center; border-radius: 0;">
          <h1 style="color: #ffffff; font-size: 36px; margin: 0 0 10px; font-weight: 700;">${propertyIcon} Naity</h1>
          <p style="color: #e0f2fe; margin: 0; font-size: 16px; font-weight: 500;">منصة حجز ${isApartment ? 'الشقق والفنادق' : 'الفنادق'} الرائدة في سوريا</p>
        </div>

        <!-- Main content -->
        <div style="padding: 40px 30px;">
          <!-- Welcome message -->
          <div style="background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%); border-radius: 12px; padding: 30px; margin-bottom: 30px; border-right: 5px solid #1a56db;">
            <h2 style="color: #0369a1; margin: 0 0 15px; font-size: 28px; font-weight: 700;">عزيزي فريق ${displayName}! 🎉</h2>
            <p style="color: #0c4a6e; margin: 0; font-size: 16px; line-height: 1.8;">
              <strong>مرحباً بكم في Naity!</strong> يسعدنا انضمامكم إلينا.
            </p>
            <p style="color: #0c4a6e; margin: 15px 0 0; font-size: 16px; line-height: 1.8;">
              تم تسجيل ${isApartment ? 'شقتكم' : 'فندقكم'} بنجاح ${isApartment ? 'وهي' : 'وهو'} الآن ${isApartment ? 'متاحة' : 'ظاهر'} لآلاف المسافرين الباحثين عن أماكن إقامة في مختلف أنحاء سوريا.
            </p>
          </div>

          <!-- Property details -->
          <div style="background: #ffffff; border: 2px solid #e2e8f0; border-radius: 12px; padding: 25px; margin-bottom: 30px;">
            <h3 style="color: #1e293b; margin: 0 0 20px; font-size: 20px; font-weight: 700; border-bottom: 2px solid #1a56db; padding-bottom: 10px;">
              📋 تفاصيل ${isApartment ? 'الشقة' : 'الفندق'}
            </h3>
            <table style="width: 100%; border-collapse: collapse;">
              <tr>
                <td style="padding: 15px 10px; border-bottom: 1px solid #f1f5f9; font-weight: 600; color: #475569; font-size: 15px;">
                  ${propertyIcon} ${propertyNameLabel.ar}
                </td>
                <td style="padding: 15px 10px; border-bottom: 1px solid #f1f5f9; color: #1e293b; font-size: 15px; font-weight: 600;">
                  ${displayName}
                </td>
              </tr>
              <tr>
