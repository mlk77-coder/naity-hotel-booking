          <p style="margin: 0 0 10px; font-weight: 600; color: #e2e8f0; font-size: 16px;">Naity Team</p>
          <p style="margin: 0 0 5px;">📧 support@naity.net | 🌐 naity.net</p>
          <p style="margin: 10px 0 0; font-size: 12px; color: #64748b;">
            © ${new Date().getFullYear()} Naity. All rights reserved.
          </p>
        </div>
      </div>
    `,
  };

  try {
    await transporter.sendMail(mailOptions);
    console.log(`📧 Hotel welcome email sent to ${contact_email} (${language})`);
    return true;
  } catch (err) {
    console.error("❌ Failed to send hotel welcome email:", err.message);
    return false;
  }
};

